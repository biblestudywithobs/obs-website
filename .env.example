# Copy this file to .env.local and fill in real values.
# See README.md for where to get each of these.

# --- Supabase (database, auth, storage) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Only needed for CLI commands (supabase db push / gen types) — not read by the app itself.
SUPABASE_ACCESS_TOKEN=

# --- Resend (transactional email) ---------------------------------------
RESEND_API_KEY=

# --- PostHog (analytics) --------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
# Personal API key + project ID, for the admin Analytics dashboard's server-side reads
# (distinct from the public write-only key above).
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# --- Spotify (Media page episode feed) -----------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Cloudflare R2 (admin-portal file uploads: class session audio, resource PDFs) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
